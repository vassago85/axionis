# Axionis POS — Demo Instance
# Copy to .env for a demo deployment with sample data

OWNER_EMAIL=demo@example.com
OWNER_PASSWORD=DemoPassword2026!
JWT_KEY=replace-with-a-random-string-at-least-32-characters-long

AXIONIS_DATA_DIR=./data
PUBLIC_BASE_URL=https://demo.your-domain.com
WEB_PORT=9095

# Enable demo seed data (Venatics Gear consignment products)
SEED_DEMO_DATA=true

