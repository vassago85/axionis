# Axionis POS — Client Production Instance
# Copy to .env for each client deployment

# ── Owner account (created on first startup) ──
OWNER_EMAIL=owner@client-business.com
OWNER_PASSWORD=SecurePassword-Change-This

# ── Security ──
JWT_KEY=generate-a-unique-random-string-at-least-32-characters

# ── Paths ──
AXIONIS_DATA_DIR=/opt/axionis/data
PUBLIC_BASE_URL=https://pos.client-business.com
WEB_PORT=9095

# ── Email (Mailgun) ──
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.client-business.com
MAILGUN_FROM=Client Business <sales@client-business.com>

# ── Optional ──
# SEED_DEMO_DATA=false
# ASPNETCORE_ENVIRONMENT=Production
