# Copy to .env (gitignored) before running `docker compose -f docker-compose.local.yml up`.
# All values are required — docker-compose.local.yml now refuses to start without them.

# JWT signing secret. >=32 random characters. Generate one with:
#   openssl rand -base64 48
JWT_KEY=replace-me-with-a-long-random-string-please

# Optional: override the JWT issuer/audience pair. Default LocalPosDev is fine for laptops.
# JWT_ISSUER=LocalPosDev
# JWT_AUDIENCE=LocalPosDev

# Initial owner account that the API auto-seeds on first run. Change the password
# immediately after first login (Settings -> Account / Password).
OWNER_EMAIL=admin@example.local
OWNER_PASSWORD=ChangeMe2026!
